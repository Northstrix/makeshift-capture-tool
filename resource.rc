#include <windows.h>
#include <winver.h>

100 PNG "logo.png"

1 VERSIONINFO
FILEVERSION 1,0,0,0
PRODUCTVERSION 1,0,0,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "https://github.com/Northstrix"
            VALUE "FileDescription", "Makeshift Capture Tool"
            VALUE "FileVersion", "1.0"
            VALUE "InternalName", "MakeshiftCaptureTool"
            VALUE "LegalCopyright", "Copyright (C) 2026 Maxim Bortnikov"
            VALUE "OriginalFilename", "MakeshiftCaptureTool.exe"
            VALUE "ProductName", "Makeshift Capture Tool"
            VALUE "ProductVersion", "1.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END